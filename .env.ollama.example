# =============================================================================
#  Configuracion para correr APU Bolivia LOCALMENTE con Ollama
#  (IA gratis, sin tokens ni limites de tasa).
#
#  USO:
#   1. Copia este archivo como  .env  (sin el .ollama) en la raiz del proyecto.
#   2. Instala Ollama: https://ollama.com  (puedes instalarlo en tu disco D:).
#   3. Descarga el modelo:   ollama pull qwen3-coder:30b
#   4. Arranca:   run_local.bat   (o:  streamlit run app.py)
# =============================================================================

# --- IA local con Ollama (gratis, sin limites) ---
USAR_LLM=true
USAR_OLLAMA=true
OLLAMA_HOST=http://localhost:11434
# Modelo potente recomendado (necesita PC con >=24 GB de RAM o GPU con >=18 GB).
#   ollama pull qwen3-coder:30b
OLLAMA_MODEL=qwen3-coder:30b
# Si tu PC va justa de RAM/lenta, baja a un modelo liviano:
#   OLLAMA_MODEL=qwen2.5:7b   (8 GB)   o   qwen2.5:3b   (4 GB)
# Timeout por llamada (s). El 30B en CPU puede tardar; subelo si ves cortes.
OLLAMA_TIMEOUT=300

# --- Datos locales: sin envio de correos ni navegador ---
# Los codigos de verificacion se MUESTRAN en la consola (no se envian).
AUTH_EMAIL_DRY_RUN=true
EMAIL_DRY_RUN=true
SCRAPER_DRY_RUN=true
SEPREC_USAR_NAVEGADOR=false

# --- (Opcional) si instalaste Ollama y sus modelos en el disco D: ---
# Define esto en Windows ANTES de arrancar para guardar los modelos en D:
#   setx OLLAMA_MODELS "D:\ollama\models"
