# =========================================================================
# APU Bolivia Generator — variables de entorno
# Copia este archivo como .env y ajusta los valores.
# =========================================================================

# --- Base de datos ---
# Por defecto SQLite local. Para producción puede usarse PostgreSQL.
APU_DB_PATH=data/proveedores.db
# DATABASE_URL=postgresql://usuario:password@localhost:5432/apu_bolivia

# --- Parámetros de negocio (Bolivia) ---
APU_MONEDA=BOB
APU_TIPO_CAMBIO_USD=6.96
APU_FACTOR_INDIRECTOS=0.10
APU_FACTOR_UTILIDAD=0.10
APU_FACTOR_IMPUESTOS=0.0
APU_VIGENCIA_DIAS=30

# --- Email (Nivel 3 del cotizador) ---
# EMAIL_DRY_RUN=true  => NO envía correos reales (modo seguro por defecto).
EMAIL_DRY_RUN=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=APU Bolivia Generator
EMAIL_RECORDATORIO_DIAS=5
REGISTRO_PROVEEDOR_URL=https://apubolivia.local/registro-proveedor

# --- Scraping web (Nivel 2) ---
# SCRAPER_DRY_RUN=true => NO sale a internet, devuelve datos simulados.
SCRAPER_DRY_RUN=true
SCRAPER_TIMEOUT=10
SCRAPER_USER_AGENT=APUBoliviaBot/1.0 (+https://apubolivia.local; cotizaciones)

# --- Extracción con IA / LLM (OPCIONAL) ---
# Déjalo en false para modo 100% offline (extractor por reglas).
# Ponlo en true para usar IA (LLM local gratis y/o APIs de pago).
USAR_LLM=false

# === LLM LOCAL GRATIS (Ollama) — recomendado, sin tokens ni internet ===
# 1) Instala Ollama: https://ollama.com  2) Descarga un modelo liviano:
#      ollama pull qwen2.5:3b      (apto para 8 GB de RAM)
# 3) Activa aquí:
USAR_OLLAMA=false
OLLAMA_HOST=http://localhost:11434
# Modelo liviano por defecto (8 GB RAM). Otras opciones: gemma2:2b, llama3.1
OLLAMA_MODEL=qwen2.5:3b

# === LLMs de pago (opcionales, solo si quieres usarlos) ===
# 1) Extracción estructurada de partidas → GPT-4o
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# 2) Interpretación normativa (NB-DS 2023, NB 1225001) → Claude Sonnet
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# 3) Análisis multimodal de planos/PDF → Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-pro-exp

# --- OCR (PDFs escaneados / imágenes) ---
# Requiere instalar el binario Tesseract OCR y Poppler en el sistema operativo.
# No hay variables obligatorias; el OCR se activa solo si están instalados.

# --- Login de empresas / entidades ---
# Sal para el hash de contraseñas (CÁMBIALA en producción).
AUTH_SALT=apu-bolivia-salt-cambiar-en-produccion
# Verificación de correo: true = simulada (muestra el código en pantalla).
# false = envía el código por SMTP (requiere configurar SMTP arriba).
AUTH_EMAIL_DRY_RUN=true
# Verificación de NIT (Bolivia) vía API Verifik. Sin token se omite.
VERIFIK_TOKEN=
VERIFIK_URL=https://api.verifik.co/v2/bo/nit/{nit}

# --- Logging ---
LOG_LEVEL=INFO
