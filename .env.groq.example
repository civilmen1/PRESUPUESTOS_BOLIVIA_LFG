# =============================================================================
#  Configuracion para usar IA EN LINEA con Groq (gratis, rapida, sin tu PC).
#
#  USO:
#   1. Crea una cuenta gratis en https://console.groq.com  y genera una clave
#      en https://console.groq.com/keys
#   2. Copia este archivo como  .env  (sin el .groq) y pega tu clave abajo.
#   3. Arranca:  python -m streamlit run app.py
#
#  Sirve para: reconocer texto, ubicar materiales, leer precios subidos y
#  decidir material / mano de obra / equipo. NO depende de tu maquina.
# =============================================================================

# --- IA en linea con Groq (gratis) ---
USAR_LLM=true
USAR_OLLAMA=false
GROQ_API_KEY=pega-aqui-tu-clave-de-groq
# Modelo recomendado (potente y gratis). Alternativa rapida: llama-3.1-8b-instant
GROQ_MODEL=llama-3.3-70b-versatile

# --- Datos locales: sin envio de correos reales ---
AUTH_EMAIL_DRY_RUN=true
EMAIL_DRY_RUN=true
SCRAPER_DRY_RUN=true
SEPREC_USAR_NAVEGADOR=false
